TELEGRAM_BOT_TOKEN=
GEMINI_API_KEY=
CATALOG_JSON_PATH=./catalog.json
ORDER_RECIPIENT_PHONE_NUMBER=
# Telegram bots cannot send to a raw phone number. Put the recipient Telegram chat id here.
ORDER_RECIPIENT_CHAT_ID=
GEMINI_MODEL=gemini-2.5-flash
CATALOG_MAX_CANDIDATES=25
TELEGRAM_CONNECT_TIMEOUT=30
TELEGRAM_READ_TIMEOUT=30
TELEGRAM_WRITE_TIMEOUT=30
TELEGRAM_POOL_TIMEOUT=30
# Optional, for networks that cannot reach api.telegram.org directly.
# Examples: http://127.0.0.1:8080 or socks5://127.0.0.1:1080
TELEGRAM_PROXY_URL=
